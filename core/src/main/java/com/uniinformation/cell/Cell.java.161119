	public void setFormula(CellFormula p_formula) throws CellException
	{
		initcd();
		if(cd.formula != null) cd.formula.unsetTrigger(this);
		cd.formula = p_formula;
		if(p_formula != null) {
			cd.formula.setTrigger(this);
			eval();
		}
	}
