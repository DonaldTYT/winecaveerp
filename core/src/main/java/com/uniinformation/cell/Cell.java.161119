	public void map(CellValueMapper p_mapper) /* throws CellException */
	{
		initcd();
		if(cd.valueMapper != null) {
			cd.valueMapper.cellMap_bind(null);
		}
		if(p_mapper != null) {
			p_mapper.cellMap_bind(this);
		}
		cd.valueMapper = p_mapper;
	}
	public void eval() throws CellException
	{
		switch(jxValueType) {
		case VTYPE_INT:
		case VTYPE_DOUBLE :
					if(cd.formula != null) {
//						UniLog.log("Before Cell eval " + cd.formula.toString());
						Object o = cd.formula.eval();
//						UniLog.log("After Cell eval " + cd.formula.toString());
						if(o != null) {
							/*
							&& o instanceof Double) setDb = o.doubleValue();
							*/
							Object oo = valObj;
							try {
								set(o);
								oo = null;
							} catch (CellException ex) {
								set(oo);
								throw ex;
							}

							if(jxValueMode != VMODE_OVERRIDED) {
								switch(jxValueType) {
								case VTYPE_INT:
								if(cd != null && cd.setInt != getIntVal()) {
									setIntVal(cd.setInt);
									checkActionAndTrigger();
									if(cd.valueMapper != null) {
										cd.valueMapper.cellMap_valchange();
									}
								}
								break;
								case VTYPE_DOUBLE :
								if(cd.setDb != getDbVal()) {
									setDbVal(cd.setDb);
									checkActionAndTrigger();
									if(cd.valueMapper != null) {
										cd.valueMapper.cellMap_valchange();
									}
								}
								break;
								}
							
							}
						}
					}
					break;
		}
	}
	private void checkActionAndTrigger() throws CellException
	{
			if(cd == null) return;
			if(cd.actionList != null) {
				CellValueAction action;
				Enumeration e = cd.actionList.elements();
				while(e.hasMoreElements()) {
					/*
					if(cd.evaluatingChild) 
						throw new CellException("Recursive Evaluation Inhibited")+getIntVal() + getDbVal() + getBoolVal() + getStrVal());
					*/
					if(cd.evaluatingChild) {
						CellException ex = new CellException("Recursive Evaluation Inhibited");
						UniLog.log(ex);
						throw ex;
					}
					cd.evaluatingChild = true;
					action = (CellValueAction) e.nextElement();
					try {
//						UniLog.log("Before cellAction_onchange " + action);
						action.cellAction_onchange(this);
//						UniLog.log("After cellAction_onchange " + action);
					} catch (CellException ex) {
						cd.evaluatingChild = false;
						throw ex;
						/*
						UniLog.log(ex);
						throw new CellException(ex.toString());
						*/
					}
					cd.evaluatingChild = false;
				}
			}
			if(cd.triggerList != null) {
				Cell c;
				Enumeration e = cd.triggerList.elements();
				while(e.hasMoreElements()) {
					/*
					if(cd.evaluatingChild) throw new CellException("Recursive Evaluation Inhibited"+
										getIntVal() + getDbVal() + getBoolVal() + getStrVal());
					*/
					if(cd.evaluatingChild) {
						CellException ex = new CellException("Recursive Evaluation Inhibited");
						UniLog.log(ex);
						throw ex;
					}
					cd.evaluatingChild = true;
					c = (Cell) e.nextElement();
					try {
//						UniLog.log("Before eval " + getString());
						c.eval();
//						UniLog.log("After eval " + getString());
					} catch (CellException ex) {
						cd.evaluatingChild = false;
						throw ex;
						/*
						UniLog.log(ex);
						throw new CellException(ex.toString());
						*/
					}
					cd.evaluatingChild = false;
				}
			}
	}
	public void set(Object o) throws CellException
	{
		if(o instanceof Double) {
			set(((Double) o).doubleValue());
		} else {
			if( o instanceof String ) {
				set((String) o);
			} else {
				if( o instanceof Integer ) {
					set(((Integer) o).intValue());
				}  else {
						if( o instanceof java.util.Date) {
							set((java.util.Date) o);
						}
					}
			}
		}
	}
	public void set(String strval) throws CellException
	{
		if(jxValueType == VTYPE_BOOLEAN) {
			if(strval.equals("Y")) set(true); else set(false);
			return;
		}
		if(jxValueType != VTYPE_STRING) return;
		if(cd == null) {setStrVal(strval);return;} else cd.setStr = strval;
		if(jxValueMode != VMODE_OVERRIDED) {
			if((strval == null && getStrVal() != null) 
		  	  || !strval.equals(getStrVal())) {
				setStrVal(strval);
				checkActionAndTrigger();
				if(cd.valueMapper != null) {
					cd.valueMapper.cellMap_valchange();
				}
			} 
		}
	}

	public boolean update(Object p_value) throws NumberFormatException, CellException
	{
		initcd();
		UniLog.log("HAHA XXXX 1" + jxValueType);
		if(cd.validation != null && !cd.validation.validate(this,p_value)) {
			throw new NumberFormatException(cd.validation.getErrMsg());
		}
		if(jxValueType == VTYPE_STRING) {
			if(cd.itemList != null) {
				if(! cd.itemList.contains(p_value))
					throw new NumberFormatException("Invalid Choice ["+p_value.toString()+"]");
			}
		}
		switch(jxValueType) {
		case VTYPE_INT :	int iv = getIntVal();
								try {
									sync(((Integer) p_value).intValue());
								} catch (CellException ex) {
									UniLog.log("CellException Catched restore iv "+iv);
									if(jxValueMode == VMODE_OVERRIDED) sync(iv); else set(iv);
									return(false);
								}
								break;
		case VTYPE_DOUBLE:
								double dv = getDbVal();
								try {
									sync(((Double) p_value).doubleValue());
								} catch (CellException ex) {
									UniLog.log("CellException Catched restore dv " + dv);
									if(jxValueMode == VMODE_OVERRIDED) sync(dv); else set(dv);
									return(false);
								}
								break;
		case VTYPE_STRING :
								sync((String) p_value);
								break;
		case VTYPE_DATE   :
								if(p_value instanceof java.util.Date) {
									sync(p_value);
								} else {
									java.util.Date jd = DateUtil.getDate((String) p_value);
									sync(jd);
								}
								break;
		default : throw new NumberFormatException("Unsupported Data Format");
		}
		return(true);
	}
	public void sync(String strval) throws CellException
	{
		if((strval == null && getStrVal() != null) 
		    || !strval.equals(getStrVal())) {
			setStrVal(strval);
			if(jxValueMode == VMODE_PROTECTED) {
				setMode(VMODE_OVERRIDED);
				try {
					checkActionAndTrigger();
				} catch (CellException ex) {
					UniLog.log("cell sync string newoverride exception captured");
					setMode(VMODE_PROTECTED);
					throw(ex);
				}
			} else {
				checkActionAndTrigger();
			}
			if(cd.valueMapper != null) {
				cd.valueMapper.cellMap_valchange();
			}
			if(jxValueMode == VMODE_PROTECTED) setMode(VMODE_OVERRIDED);
		} 
	}
	public void set(int intval) throws CellException
	{
		if(jxValueType == VTYPE_INT) {
			if(cd == null) {setIntVal(intval);return;} else cd.setInt = intval;
			if(jxValueMode != VMODE_OVERRIDED) {
				if(intval != getIntVal()) {
					setIntVal(intval);
					checkActionAndTrigger();
					if(cd.valueMapper != null) {
						cd.valueMapper.cellMap_valchange();
					}
				}
			}
		}  else {
			if(jxValueType == VTYPE_BOOLEAN) {
				if(intval == 0) set(false); else set(true);
			}
		}
	}
	public void sync(int intval) throws NumberFormatException ,CellException
	{
		if(intval != getIntVal()) {
			UniLog.log("syncMode override " + cd.setInt);
			setIntVal(intval);
			if(jxValueMode == VMODE_PROTECTED) {
				setMode(VMODE_OVERRIDED);
				try {
					checkActionAndTrigger();
				} catch (CellException ex) {
					UniLog.log("cell sync int newoverride exception captured");
					setMode(VMODE_PROTECTED);
					throw(ex);
				}
			} else {
				checkActionAndTrigger();
			}
			if(jxValueMode == VMODE_PROTECTED) setMode(VMODE_OVERRIDED);
			if(cd != null && cd.valueMapper != null) {
				cd.valueMapper.cellMap_valchange();
			}
		}
	}
	public void set(java.util.Date d) throws CellException
	{
		if(jxValueType == VTYPE_DATE) {
			if(cd == null) {setDateVal(d);return;} else cd.setDate = d;
			if(jxValueMode != VMODE_OVERRIDED) {
				if(d != getDateVal()) {
					setDateVal(d);
					checkActionAndTrigger();
					if(cd.valueMapper != null) {
						cd.valueMapper.cellMap_valchange();
					}
				}
			}
		}
	}
	public void sync(java.util.Date d) throws CellException
	{
		if(d != getDateVal()) {
			UniLog.log("syncMode override " + cd.setInt);
			setDateVal(d);
			if(jxValueMode == VMODE_PROTECTED) {
				setMode(VMODE_OVERRIDED);
				try {
					checkActionAndTrigger();
				} catch (CellException ex) {
					UniLog.log("cell sync int newoverride exception captured");
					setMode(VMODE_PROTECTED);
					throw(ex);
				}
			} else {
				checkActionAndTrigger();
			}
			if(jxValueMode == VMODE_PROTECTED) setMode(VMODE_OVERRIDED);
			if(cd != null && cd.valueMapper != null) {
				cd.valueMapper.cellMap_valchange();
			}
		}
	}
	public void sync(Object o) throws CellException
	{
		boolean forceOverride = false;
		if(cd == null) {
			if(jxValueMode != 0) {
				initcd();
				UniLog.log("sync object called to cell with no celldetail call initcd");
				forceOverride = true;
			} else {
				UniLog.log("sync object called to cell with no celldetail, use setvalue");
				set(o);
				return;
			}
		}
		if(cd.validation != null && !cd.validation.validate(this,o)) {
			throw new CellException(cd.validation.getErrMsg());
		}
		switch(jxValueType) {
		case VTYPE_BOOLEAN: {
					boolean b = false;
					if(o instanceof Double) {
						int i = (int) (((Double) o).doubleValue());
						if(i != 0) b = true; else b = false;
					} else {
						if( o instanceof String ) {
							String s = (String) o;
							if(o.equals("Y")) b = true; else b = false;
							sync((String) o);
						} else {
							if( o instanceof Integer ) {
								int i = ((Integer) o).intValue();
								if(i != 0) b = true; else b = false;
							} else {
								if( o instanceof Boolean ) {
									b = ((Boolean) o).booleanValue();
								}
							}
						}
					}
					sync(b);
				}
				break;
		case VTYPE_INT: {
					int n = 0;
					if(o instanceof Double) {
						n = (int) (((Double) o).doubleValue());
					} else {
						if( o instanceof String ) {
							n = Integer.parseInt((String) o);
						} else {
							if( o instanceof Integer ) {
								n = ((Integer) o).intValue();
							} else {
								if( o instanceof Boolean ) {
									boolean b;
									b = ((Boolean) o).booleanValue();
									if(b) n = 1; else n = 0;
								}
							}
						}
					}
					sync(n);
				}
				break;
		case VTYPE_STRING: {
					sync(o.toString());
				}
				break;
		case VTYPE_DOUBLE: {
					double d = 0.0;
					if(o instanceof Double) {
						d = ((Double) o).doubleValue();
					} else {
						if( o instanceof String ) {
							d = Double.parseDouble((String) o);
						} else {
							if( o instanceof Integer ) {
								d = (double) (((Integer) o).intValue());
							} else {
								if( o instanceof Boolean ) {
									boolean b;
									b = ((Boolean) o).booleanValue();
									if(b) d = 1.0; else d = 0.0;
								}
							}
						}
					}
					sync(d);
				}
				break;
		case VTYPE_DATE :
					sync((java.util.Date) o);
				break;
		default:
			UniLog.log("Unsupported Sync Object Ignored " + o);
		}
		if(forceOverride) {
			if(jxValueMode == VMODE_PROTECTED) {
				jxValueMode = VMODE_OVERRIDED;
			}
		}
	}
	public void set(double dbval) throws CellException
	{
		if(jxValueType == VTYPE_DOUBLE) {
			if(cd == null) {setDbVal(dbval);return;} else cd.setDb = dbval;
			if(jxValueMode != VMODE_OVERRIDED) {
				if(dbval != getDbVal()) {
					setDbVal(dbval);
					checkActionAndTrigger();
					if(cd.valueMapper != null) {
						cd.valueMapper.cellMap_valchange();
					}
				}
			}
		}
		if(jxValueType == VTYPE_INT) {
			if(cd == null) {setIntVal((int) dbval);return;} else cd.setInt = (int) dbval;
			if(jxValueMode != VMODE_OVERRIDED) {
				if(cd.setInt != getIntVal()) {
					setIntVal(cd.setInt);
					checkActionAndTrigger();
					if(cd.valueMapper != null) {
						cd.valueMapper.cellMap_valchange();
					}
				}
			}
		}
	}
	public void sync(double dbval) throws CellException
	{
		if(dbval != getDbVal()) {
			setDbVal(dbval);
			if(jxValueMode == VMODE_PROTECTED) {
				setMode(VMODE_OVERRIDED);
				try {
					checkActionAndTrigger();
				} catch (CellException ex) {
					UniLog.log("cell sync double newoverride exception captured");
					setMode(VMODE_PROTECTED);
					throw(ex);
				}
			} else {
				checkActionAndTrigger();
			}
			if(cd.valueMapper != null) {
				cd.valueMapper.cellMap_valchange();
			}
		}
	}
	public void set(boolean boolval) throws CellException
	{
		if(jxValueType != VTYPE_BOOLEAN) return;
		if(cd == null) {setBoolVal(boolval);return;} else cd.setBool = boolval;
		if(jxValueMode != VMODE_OVERRIDED) {
			if(boolval != getBoolVal()) {
				setBoolVal(boolval);
				checkActionAndTrigger();
				if(cd.valueMapper != null) {
					cd.valueMapper.cellMap_valchange();
				}
			}
		}
	}
	public void sync(boolean boolval) throws CellException
	{
		if(boolval != getBoolVal()) {
			setBoolVal(boolval);
			if(jxValueMode == VMODE_PROTECTED) {
				setMode(VMODE_OVERRIDED);
				try {
					checkActionAndTrigger();
				} catch (CellException ex) {
					UniLog.log("cell sync boolean newoverride exception captured");
					setMode(VMODE_PROTECTED);
					throw(ex);
				}
			} else {
				checkActionAndTrigger();
			}
			if(jxValueMode == VMODE_PROTECTED) setMode(VMODE_OVERRIDED);
			if(cd.valueMapper != null) {
				cd.valueMapper.cellMap_valchange();
			}
		}
	}

	public int getType()
	{
		return(jxValueType);
	}
	public Object getObject() {
		switch(jxValueType) {
		case VTYPE_STRING : return(getString());
		case VTYPE_DOUBLE : return(new Double(getDouble()));
		case VTYPE_INT		: return(new Integer(getInt()));
		case VTYPE_BOOLEAN: return(new Boolean(getBoolean()));
		case VTYPE_BYTEARRAY: return(getByteArray());
		case VTYPE_DATE   : return(getDate());
		default 			   : return("Unknown Value");
		}
	}
	public String getString()
	{
		switch(jxValueType) {
		case VTYPE_STRING : return(getStrVal());
		/*
		case VTYPE_DOUBLE : return(Double.toString(getDbVal()));
		*/
		case VTYPE_DOUBLE : if(cd != null && cd.format != null)
										return(cd.format.format(getDbVal()));
								  else
										return(defaultDoubleFormat.format(getDbVal()));
		case VTYPE_INT		: if(cd != null && cd.format != null)
										return(cd.format.format(getIntVal()));
								  else
										return(Integer.toString(getIntVal()));
		case VTYPE_BOOLEAN: if(getBoolVal()) return("Y");else return("N");
		case VTYPE_BYTEARRAY: if(getBaVal() != null) return("[ByteArray]");else return("");
		case VTYPE_DATE   : if (getDateVal() != null) 
	                          return(DateUtil.toDateString(getDateVal(), "yyyy/mm/dd"));
		                    else
		                       return("");
		default 			   : return("Unknown Value");
		}
	}
	public int getInt()
	{
		if(jxValueType == VTYPE_INT) return(getIntVal());
		if(jxValueType == VTYPE_DOUBLE) return((int) getDbVal());
		return(0);
	}

	public double getDouble()
	{
		switch(jxValueType) {
		case VTYPE_DOUBLE : return(getDbVal());
		case VTYPE_INT		: return((double) getIntVal());
		case VTYPE_BOOLEAN: if(getBoolVal()) return(1.0) ; else return(0.0);
		default : return(0.0);
		}
	}

	public boolean getBoolean()
	{
		switch(jxValueType) {
		case VTYPE_BOOLEAN : return(getBoolVal());
		case VTYPE_INT     : return((getIntVal() != 0));
		default	: return(false);
		}
	}
	public byte[] getByteArray()
	{
		if(jxValueType != VTYPE_BYTEARRAY) return(null);
		return(getBaVal());
	}
	public java.util.Date getDate()
	{
		if(jxValueType != VTYPE_DATE) return(null);
		return(getDateVal());
	}
	public void setHint(String p_hint)
	{
		initcd();
		cd.hintContent = p_hint;
		if(cd.valueMapper != null) {
			cd.valueMapper.cellMap_hintchange();
		}
	}
	public String getHint()
	{
		initcd();
		return(cd.hintContent);
	}
	public void syncHint(String p_hint)
	{
		initcd();
		cd.hintContent = p_hint;
	}
	public void setMode(int p_mode) throws CellException
	{
		int orgmode = jxValueMode;
		jxValueMode = p_mode;
		if(cd != null && cd.valueMapper != null) {
			cd.valueMapper.cellMap_modechange();
			if(orgmode != p_mode && cd.modeChangeAction != null) 
						cd.modeChangeAction.cellAction_onchange(this);
		}
	}
	public void syncMode(int p_mode) throws CellException
	{
		int orgMode;
		orgMode = jxValueMode;
		if(jxValueMode != p_mode){
			jxValueMode = p_mode;
			if(orgMode == VMODE_OVERRIDED) {
				switch(jxValueType) {
				case VTYPE_INT : 
							UniLog.log("syncMode restore " + cd.setInt);
							set(cd.setInt); 
							break;
				case VTYPE_STRING : set(cd.setStr); break;
				case VTYPE_DOUBLE: set(cd.setDb); break;
				case VTYPE_BOOLEAN: set(cd.setBool); break;
				}
			}
			if(cd != null && cd.modeChangeAction != null) 
						cd.modeChangeAction.cellAction_onchange(this);
		}
	}
	public int getMode()
	{
		return(jxValueMode);
	}
	public void addAction(CellValueAction p_action)
	{	
		initcd();
