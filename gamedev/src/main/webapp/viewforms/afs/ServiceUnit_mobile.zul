<zk>
<script><![CDATA[
zk.afterLoad('zul.inp', function() {
	var xBandbox = {};
	zk.override(zul.inp.Bandbox.prototype, xBandbox ,{
		_checkPopupSpaceAndPosition : function(pp, inp) {
			console.log("in override bandbox checkposition");
			var $pp = zk(pp);
			var ppHeight = $pp.dimension().height;
			var ppWidth = $pp.dimension().width;
			var inpDim = (inp.nodeType ? zk(inp) : inp).dimension(true);
			var inpTop = inpDim.top;
			var inpHeight = inpDim.height;
			var screenY = jq.innerY();
			var screenHeight = jq.innerHeight();
			
			var inpLeft = inpDim.left;
			var inpWidth = inpDim.width;
			var screenX = jq.innerX();
			var screenWidth = jq.innerWidth();
			
			var hPosition;
			
			/*
			console.log("in override bandbox dim screenX " + screenX + " screenWidth " + screenWidth + " inpLeft " + inpLeft + " inpWidth " + inpWidth + " ppWidth " + ppWidth);
			if (screenX + screenWidth - inpLeft - inpWidth > ppWidth) {	
				console.log("use a");
				hPosition = 'start';
			} else if (inpLeft + inpWidth - screenX > ppWidth) {
				console.log("use b");
				hPosition = 'end';
			} else {
				console.log("use c");
				hPosition = 'start';
			}
			*/
			console.log("in override bandbox checkposition hPosition = " + hPosition);
			
			$pp.position(inp, 'after_end', {overflow: true});
		}
	});//zk.override
});//zk.afterLoad
]]></script>
