	<listbox id="list_erpv4_QuoInvoiceG2" vflex="1" sclass="zkbi-summary-footer">
	   <listfoot>
        <listfooter id="footer_list_erpv4_QuoInvoiceG2" span="5"><div style="text-align:right;padding:4px 5px;"></div></listfooter>
        <listfooter span="1"></listfooter>
        <listfooter span="2"><div style="text-align:right;padding:4px 5px;"></div></listfooter>
       </listfoot>
	</listbox>
	
			</tabpanel>
			<tabpanel>
				<separator height="20px"/>
				<bs-row style="background:white">
					<div sclass="col-12 col-lg-3">
						<zkbidiv jxId="inv_invtotal"></zkbidiv>
						<zkbidiv jxId="inv_cansendinv"></zkbidiv>
						<zkbidiv jxId="inv_hassendinv"></zkbidiv>
					</div>
					<div sclass="col-12 col-lg-3">
						<zkbidiv jxId="inv_completed"></zkbidiv>
						<zkbidiv jxId="inv_compadj"></zkbidiv>
						<zkbidiv jxId="inv_compremark" compWidth="300px"></zkbidiv>
					</div>
				</bs-row>
			</tabpanel>
			<tabpanel>
				<listbox id="list_erpv4_OrdersAttach" vflex="1" sclass="zkbi-summary-footer"/>
			</tabpanel>
		</tabpanels>
	</tabbox>
	<template name="template_erpv4_QuoDetG2_ind_typediv" twidth="hflex=min">
		 	<vlayout>
			<hlayout>
			<zkbidiv jxId="ind_itemno" labelPosition="invisible"></zkbidiv>
			<zkbidiv jxId="ind_pdsrg" labelPosition="invisible"></zkbidiv>
			</hlayout>
			<div style="text-align:right">
			<zkbidiv jxId="ind_subitem" labelWidth="80px"></zkbidiv>
			</div>
		 	</vlayout>
	</template>
	<template name="template_erpv4_QuoDetG2_ind_itemdiv" twidth="hflex=min">
			<hlayout>
		 	<vlayout>
			<zkbidiv jxId="st_icode"></zkbidiv>
			<zkbidiv jxId="ind_ref1"></zkbidiv>
			<zkbidiv jxId="ind_ref2"></zkbidiv>
		 	</vlayout>
		 	<vlayout>
			<zkbidiv jxId="ind_desc" labelPosition="invisible" visible="false"></zkbidiv>
			<zkbidiv jxId="stbd_pickname" ></zkbidiv>
			<zkbidiv jxId="st_pickmodel" ></zkbidiv>
		 	</vlayout>
			</hlayout>
	</template>
	<template name="template_erpv4_QuoDetG2_ind_qtydiv" twidth="195px">
		 	<vlayout>
		 	<hlayout>
		 	<div width="10px"></div>
			<zkbidiv jxId="ind_qty" labelPosition="invisible"></zkbidiv>
			<zkbidiv jxId="ind_unit" labelPosition="invisible"></zkbidiv>
		 	</hlayout>
		 	<div id="ind_ratiodiv" visible="false">
		 	<hlayout>
		 	<div width="10px">x</div>
			<zkbidiv jxId="ind_eratio" labelPosition="invisible"></zkbidiv>
			<zkbidiv jxId="stur_ratiounit" labelPosition="invisible"></zkbidiv>
		 	</hlayout>
		 	</div>
		 	<hlayout>
		 	<div width="10px"></div>
			<zkbidiv jxId="ind_promostr" labelPosition="invisible"></zkbidiv>
			</hlayout>
		 	<hlayout>
		 	<div width="10px"></div>
			<zkbidiv jxId="ind_rpricestr" labelPosition="invisible"></zkbidiv>
			</hlayout>
			<hlayout>
			<!-- 
			<label>+</label>
			<zkbidiv jxId="ind_vat" labelWidth="60px" compWidth="100px" labelPosition="invisible"></zkbidiv>
			<label>% Vat</label>
			 -->
			<zkbidiv jxId="ind_vat" labelWidth="60px"></zkbidiv>
			<label>%</label>
			</hlayout>
		 	</vlayout>
	</template>
	<template name="template_erpv4_QuoDetG2_ind_pricediv" twidth="225px">
			<vlayout>
		 	<hlayout>
			<zkbidiv jxId="ind_sprice"></zkbidiv>
		 	</hlayout>
		 	<hlayout>
			<zkbidiv jxId="ind_uprice"></zkbidiv>
			<!-- 
			<zkbidiv jxId="stur_priceunit" labelPosition="invisible"></zkbidiv>
			 -->
		 	</hlayout>
		 	<hlayout>
			<zkbidiv jxId="ind_discpercent"></zkbidiv>
			<label>%</label>
		 	</hlayout>
			</vlayout>
	</template>
	<template name="template_erpv4_QuoDetG2_ind_amountdiv" twidth="188px">
		 	<hlayout>
		 	<!-- <zkbidiv jxId="ind_setamount" labelPosition="invisible" CompWidth="180px" CompStyle="text-align:right;"></zkbidiv> -->
			<zkbidiv jxId="ind_setamount" labelPosition="invisible" CompWidth="180px"/>
		 	</hlayout>
	</template>

