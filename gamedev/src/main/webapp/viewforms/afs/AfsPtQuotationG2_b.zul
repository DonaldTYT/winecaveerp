<zk xmlns:n="native">

<style dynamic="true">
div.z-grid.zkbi-detail-grid > div.z-grid-body {
	height: auto;
}
div.z-grid.zkbi-detail-grid {
   border: 1px solid transparent;
}
.list_erpv4_QuoDetG2xx .z-listbox-body {
<!-- 
    min-height: 200px;
    min-height: 40vh;
 -->
    height: 45vh;
}
/*
 .zkbi-linkcomp-listbox .z-listbox-body { 
 }
 */
div.list_erpv4_QuoDetG2 td.z-listcell {
	vertical-align: top;
}
div.list_erpv4_QuoDetG2 td.z-listbox-footer {
	background: white;
}
</style>
	<div class="zkbi-detail-toolbar-container">
		<div class="zkbi-detail-toolbar-leftarea">
			<button id="btPrintQuo" label="Print Quo" visible="true" disabled="false"><custom-attributes tlkey="bt_printquo"></custom-attributes></button>
			<button id="btPrintCon" label="Print Contract" visible="true" disabled="false"><custom-attributes tlkey="bt_printcon"></custom-attributes></button>
			<button id="btPrintInv" label="Print Inv" visible="false" disabled="false"><custom-attributes tlkey="bt_printinv"></custom-attributes></button>
		</div>
		<toolbar id="detail_toolbar" align="end">
		</toolbar>
	</div>
	<bs-row style="background:white">
		<div sclass="col-12 col-lg-6">
			<zkbifdiv jxId="inv_quostatus"></zkbifdiv>
			<zkbifdiv jxId="vd_vcode"></zkbifdiv>
			<zkbifdiv jxId="svloc_desp"></zkbifdiv>
			<div visible="false">
				<textbox id="vd_bsnature"/>
			</div>
			<zkbifdiv jxId="inv_addr0"></zkbifdiv>
			<zkbifdiv jxId="inv_addr1"></zkbifdiv>
			<hlayout>
			<zkbifdiv jxId="inv_addr2"></zkbifdiv>
			<!-- 
			<zkbifdiv jxId="inv_addr3"></zkbifdiv>
			 -->
			<zkbidiv jxId="inv_addr3" labelWidth="60px" compWidth="150px"></zkbidiv>
			</hlayout>
			<hlayout>
			<zkbifdiv jxId="inv_contact"></zkbifdiv>
			<!-- 
			<zkbifdiv jxId="inv_tel" labelWidth="300px" compWidth="30px"></zkbifdiv>
			 -->
			<zkbidiv jxId="inv_tel" labelWidth="60px" compWidth="150px"></zkbidiv>
			<zkbidiv jxId="inv_email" labelWidth="40px" compWidth="200px"></zkbidiv>
			</hlayout>
			<hlayout>
			<zkbifdiv jxId="inv_remark" compWidth="640px"></zkbifdiv>
			</hlayout>
		</div>
		<div sclass="col-12 col-lg-1">
		</div>
		<div sclass="col-12 col-lg-5">
			<hlayout>
			<zkbifdiv jxId="inv_quonum"></zkbifdiv>
			<zkbifdiv jxId="inv_quodate"></zkbifdiv>
			</hlayout>
			<hlayout>
			<zkbifdiv jxId="inv_invno"></zkbifdiv>
			<zkbifdiv jxId="inv_date"></zkbifdiv>
			</hlayout>
			<hlayout>
			<zkbifdiv jxId="inv_contract"></zkbifdiv>
			<zkbifdiv jxId="inv_validdays"></zkbifdiv>
			</hlayout>
			<hlayout>
			<!--
			<zkbifdiv jxId="inv_quotbcd"></zkbifdiv>
			-->
			<zkbifdiv jxId="inv_delidays"></zkbifdiv>
			<zkbifdiv jxId="inv_delidate"></zkbifdiv>
			</hlayout>
			<hlayout>
			<zkbifdiv jxId="inv_termtype"></zkbifdiv>
			<zkbifdiv jxId="inv_duedate" labelWidth="50px"></zkbifdiv>
			</hlayout>
			<hlayout>
			<zkbifdiv jxId="vd_priceclass"></zkbifdiv>
			<zkbifdiv jxId="inv_approveby"></zkbifdiv>
			</hlayout>
			<vlayout>
			<zkbifdiv jxId="sm_code"></zkbifdiv>
			<hlayout>
			<zkbifdiv jxId="sm_name" compWidth="100px"></zkbifdiv>
			<zkbifdiv jxId="sm2_name" labelWidth="50px"></zkbifdiv>
			</hlayout>
			</vlayout>
			<!-- 
			<hlayout>
			<zkbifdiv jxId="inv_pschs0"></zkbifdiv>
			<zkbifdiv jxId="inv_psch0" labelWidth="50px"></zkbifdiv>
			<zkbifdiv jxId="inv_psch1" labelWidth="50px"></zkbifdiv>
			<zkbifdiv jxId="inv_psch2" labelWidth="50px"></zkbifdiv>
			</hlayout>
			-->
			<hlayout>
			<zkbifdiv jxId="inv_psch0" labelWidth="50px"></zkbifdiv>
			<zkbifdiv jxId="inv_pschs0" labelWidth="50px"></zkbifdiv>
			</hlayout>
			<hlayout>
			<zkbifdiv jxId="inv_psch1" labelWidth="50px"></zkbifdiv>
			<zkbifdiv jxId="inv_pschs1" labelWidth="50px"></zkbifdiv>
			</hlayout>
			<hlayout>
			<zkbifdiv jxId="inv_psch2" labelWidth="50px"></zkbifdiv>
			<zkbifdiv jxId="inv_pschs2" labelWidth="50px"></zkbifdiv>
			</hlayout>
		</div>
		
	</bs-row>
	<tabbox id="zkbiListTop" width="100%" sclass="zkbi-detail-tabbox" height="55vh">
		<tabs width="100%" visible="true">
			<tab><custom-attributes tlkey="tp_item_detail"></custom-attributes>Item Detail</tab>
			<tab visible="false"><custom-attributes tlkey="tp_delivery_info"></custom-attributes>Delivery Information XX</tab>
			<tab visible="false" id="tp_invoices"><custom-attributes tlkey="tp_invoices"></custom-attributes>Invoices</tab>
			<tab visible="false" id="tp_compstatus"><custom-attributes tlkey="tp_compstatus"></custom-attributes>Completion status</tab>
			<tab visible="false" id="tp_attach"><custom-attributes tlkey="tp_attach"></custom-attributes>Attach</tab>
		</tabs>
		<tabpanels>
			<tabpanel> 
	<listbox id="list_erpv4_QuoDetG2" sclass="zkbi-summary-header" vflex="1">
	   <auxhead>
        <auxheader id="footer_list_erpv4_QuoDetG2" colspan="7">
        	<vlayout sclass="nopadding">
        		<hlayout>
				<zkbidiv jxId="inv_term" labelWidth="150px"></zkbidiv>
        		</hlayout>
        		<hlayout>
				<zkbidiv jxId="inv_quodeli" labelWidth="150px"></zkbidiv>
        		</hlayout>
        	</vlayout>
        </auxheader>
        <auxheader colspan="1"><div style="text-align:right;padding:4px 5px;"></div>
				<zkbidiv jxId="inv_cid" labelWidth="40px"></zkbidiv>
        </auxheader>
        <auxheader colspan="1"><div style="text-align:right;padding:4px 5px;"></div>
        	<div style="text-align:right;padding:4px 5px;">
        	<vlayout sclass="nopadding">
				<zkbidiv jxId="inv_grtotal"></zkbidiv>
				<zkbidiv jxId="inv_discount"></zkbidiv>
				<zkbidiv jxId="inv_total" labelWidth="45px"></zkbidiv>
        	<!-- 
        		<hlayout>
				<zkbidiv jxId="inv_cid"></zkbidiv>
        		</hlayout>
        		<hlayout>
        		</hlayout>
        	 -->
        	</vlayout>
        	</div>
        </auxheader>
       </auxhead>
	</listbox>
			
			</tabpanel>
			<tabpanel>
	<bs-row style="background:white">
		<div sclass="col-xl-6 col-lg-12">
			<zkbifdiv jxId="inv_duedays"></zkbifdiv>
		</div>
		<div sclass="col-xl-2 col-lg-6">
			<zkbifdiv jxId="inv_cuser"></zkbifdiv>
			<zkbifdiv jxId="inv_cdate"></zkbifdiv>
			<zkbifdiv jxId="inv_uuser"></zkbifdiv>
			<zkbifdiv jxId="inv_udate"></zkbifdiv>
			<zkbifdiv jxId="inv_rg"></zkbifdiv>
		</div>
	</bs-row>

	
			</tabpanel>
			<tabpanel>
