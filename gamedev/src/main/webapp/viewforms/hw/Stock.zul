			<cell>
				<hlayout valign="middle">
					<textbox id="st_mszrange" width="150px"></textbox>
					<div width="20px"></div>
					<label>Area</label>
					<doublebox id="st_dimension" width="80"></doublebox>
					<label>sqm</label>
				</hlayout>
			</cell>
			<cell></cell>
			<cell>
			</cell>
		</row>
