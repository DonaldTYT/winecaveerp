				<label id="st_lastsprice"></label>
				</hlayout>
			</cell>
			 -->
			<cell align="right"><label value="Composite Unit 1"><custom-attributes tlkey="lb_st_munit2"></custom-attributes></label> </cell>
			<cell>
				<hlayout valign="middle">
				<textbox width="60px" id="st_munit2"/>
				<label>=</label>
				<doublebox width="40px" id="st_msize2"></doublebox>
				<textbox width="60px" id="st_dunit2"/>
				</hlayout>
			</cell>
			<cell>
			</cell>
		</row>
		<row>
			<!-- 
			<cell colspan="2"></cell>
			<cell align="right"><label value="Discount 1"><custom-attributes tlkey="lb_st_price1"></custom-attributes></label> </cell>
			<cell>
				<hlayout valign="middle">
					<doublebox width="100px" id="st_price1"></doublebox>
					<label>or</label>
					<doublebox width="40px" id="st_disc1"></doublebox>
					<label>%</label>
				</hlayout>
			</cell>
			 -->
			<cell align="right"><label value="Composite Unit 1"><custom-attributes tlkey="lb_st_munit3"></custom-attributes></label> </cell>
			<cell>
				<hlayout valign="middle">
				<textbox width="60px" id="st_munit3"/>
				<label>=</label>
				<doublebox width="40px" id="st_msize3"></doublebox>
				<textbox width="60px" id="st_dunit3"/>
				</hlayout>
			</cell>
			<cell></cell>
			<cell>
			</cell>
		</row>
		<row>
			<!-- 
			<cell colspan="2"></cell>
			<cell align="right"><label value="Discount 2"><custom-attributes tlkey="lb_st_price2"></custom-attributes></label> </cell>
			<cell>
				<hlayout valign="middle">
					<doublebox width="100px" id="st_price2"></doublebox>
					<label>or</label>
