				</hlayout>
			</cell>
			 -->
			<cell align="right"><label>Dimension</label> </cell>
			<cell>
				<hlayout valign="middle">
					<combobox id="st_dimensionunit" width="115px"></combobox>
					<div width="10px"></div>
					<label>Width</label>
					<doublebox id="st_dimensionw" width="80px"></doublebox>
					<div width="10px"></div>
					<label>Length</label>
					<doublebox id="st_dimensionl" width="80px"></doublebox>
