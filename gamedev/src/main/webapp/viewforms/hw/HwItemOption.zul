<zk>
<style>
div.z-grid.option-detail-grid
{ 
	text-align: left;
	border: 1px solid #d6d6d6;
} 
div.z-grid.option-detail-grid > div.z-grid-body {
	background: #fdfdfd !important;
}
div.z-grid.option-detail-grid > div.z-grid-body > table > tbody tr.z-row td.z-row-inner {
	background: #fdfdfd !important;
}
div.z-grid.option-detail-grid > div.z-grid-body > table > tbody tr.z-row.z-row.z-grid-odd td.z-row-inner {
	background: #fdfdfd !important;
}
</style>
<div>
		<vlayout>
