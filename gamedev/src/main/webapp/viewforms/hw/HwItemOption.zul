			</vlayout>
		</hlayout>
		<hlayout valign="top">
			<div width="150px" height="30px">Job Options :-</div>
			<vlayout>
        	<grid id="hw_optionlist" use="com.uniinformation.jx.zk.ZkJxCheckListBox" sclass="option-detail-grid"> </grid>
			</vlayout>
		</hlayout>
