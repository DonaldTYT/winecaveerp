			<zkbidiv jxId="vd_priceclass"></zkbidiv>
			<zkbidiv jxId="vd_termtype"></zkbidiv>
			<zkbidiv jxId="vd_remark"></zkbidiv>
		 -->
			<zkbifdiv jxId="vd_vcode"></zkbifdiv>
			<zkbifdiv jxId="vd_vname"></zkbifdiv>
			<zkbifdiv jxId="vd_chnname"></zkbifdiv>
