<zk xmlns:n="native">
<style dynamic="true">
div.z-grid.zkbi-detail-grid > div.z-grid-body {
	height: auto;
}
div.z-grid.zkbi-detail-grid {
   border: 1px solid transparent;
}
.list_erpv4_MoDetG2 .z-listbox-body {
<!-- 
    min-height: 200px;
    min-height: 40vh;
 -->
    height: 45vh;
}
/*
 .zkbi-linkcomp-listbox .z-listbox-body { 
 }
 */
div.list_erpv4_MoDetG2 td.z-listcell {
	vertical-align: top;
}
div.list_erpv4_MoDetG2 td.z-listbox-footer {
	background: white;
}
 
</style>
	<div class="toolbar-container">
		<div class="toolbar-leftarea">
		<!--
			<zkbidiv jxId="vd_vcode"></zkbidiv>
			<zkbidiv jxId="vd_vname"></zkbidiv>
		  -->
		</div>
		<toolbar id="detail_toolbar" align="end">
		</toolbar>
	</div>
							<bs-row style="background:white">
							<div sclass="col-xl-6 col-lg-12">
							<hlayout>
							<zkbidiv jxId="stm_date" compWidth="120px"></zkbidiv>
							<zkbidiv jxId="stm_ref1" compWidth="120px"></zkbidiv>
							</hlayout>
							<zkbidiv jxId="floc_desc" compWidth="405px"></zkbidiv>
							<zkbidiv jxId="tloc_desc" compWidth="405px"></zkbidiv>
							<zkbidiv jxId="cldoc_name" compWidth="405px"></zkbidiv>
							<zkbidiv jxId="vd_vcode" compWidth="405px"></zkbidiv>
							<zkbidiv jxId="vd_vname" compWidth="405px"></zkbidiv>
							<hlayout>
							<zkbidiv jxId="stm_ref3" compWidth="120px"></zkbidiv>
							<zkbidiv jxId="stm_ref4" compWidth="120px"></zkbidiv>
							</hlayout>
							<zkbidiv jxId="stm_ctrspec" compWidth="405px"></zkbidiv>
							</div>
							<div sclass="col-xl-4 col-lg-6">
							<zkbidiv jxId="stm_status"></zkbidiv>
							<zkbidiv jxId="vd_termtype"></zkbidiv>
							<zkbidiv jxId="stm_cur"></zkbidiv>
							</div>
							<div sclass="col-xl-2 col-lg-6">
							<zkbidiv jxId="stm_mrg"></zkbidiv>
							<zkbidiv jxId="stm_cuser"></zkbidiv>
							<zkbidiv jxId="stm_cdate"></zkbidiv>
							<zkbidiv jxId="stm_uuser"></zkbidiv>
							<zkbidiv jxId="stm_udate"></zkbidiv>
							<zkbidiv jxId="stm_nref1"></zkbidiv>
							</div>
						</bs-row>
	<listbox id="list_erpv4_MoDetG2">
	   <auxhead>
        <auxheader zclass="z-listbox-footer" colspan="4">
        </auxheader>
        <auxheader zclass="z-listbox-footer" colspan="2">
        	<div style="text-align:right;padding:4px 5px;">
				<zkbidiv jxId="stm_totalcnt"></zkbidiv>
        	</div>
        </auxheader>
        <auxheader zclass="z-listbox-footer" colspan="2">
        	<div style="text-align:right;padding:4px 5px;">
        	<vlayout sclass="nopadding">
				<zkbidiv jxId="stm_grosstotal"></zkbidiv>
				<zkbidiv jxId="stm_discount"></zkbidiv>
				<zkbidiv jxId="stm_nettotal"></zkbidiv>
        	</vlayout>
        	</div>
        </auxheader>
       </auxhead>	
