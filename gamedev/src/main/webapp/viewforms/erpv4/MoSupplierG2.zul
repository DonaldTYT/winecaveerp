				<zkbidiv jxId="stm_nettotal"></zkbidiv>
        	</vlayout>
        </listfooter>
       </listfoot>
         -->
	</listbox>
	
	<!--
	<grid id="detail_grid"  sclass="zkbi-detail-grid"> </grid>
	 -->
	
	
	<template name="template_erpv4_MoDetG2_stmdo_name" twidth="100px">
		<div>
			<radiogroup id="stmdo_name" orient="vertical"></radiogroup>
		</div>
	</template>	
	<template name="template_erpv4_MoDetG2_stmd_itemdiv" twidth="hflex=min">
		<vlayout>
		<!-- 
			<hlayout>
				<label>Item Code</label>
				<bandbox id="st_icode" use="com.uniinformation.jx.zk.ZkJxPickInput"/>
			</hlayout>
		 -->
		 	<hlayout>
			<zkbidiv jxId="st_icode" labelPosition="invisible"></zkbidiv>
			<zkbidiv jxId="mt_tpname" labelWidth="60px"></zkbidiv>
		 	</hlayout>
			<zkbidiv jxId="st_iname" labelPosition="invisible"></zkbidiv>
		 	<hlayout>
			<zkbidiv jxId="st_modelno" labelPosition="invisible"></zkbidiv>
			<zkbidiv jxId="st_oicode" labelPosition="invisible"></zkbidiv>
			</hlayout>
			<!-- 
			<label id="st_iname"></label>
			 -->
		</vlayout>
	</template>	
	<template name="template_erpv4_MoDetG2_stmd_serialdiv" twidth="hflex=min">
		<vlayout>
			<zkbidiv jxId="stmd_ref4" labelPosition="invisible"></zkbidiv>
		 	<hlayout>
			<zkbidiv jxId="stmd_exprdate" labelPosition="invisible"></zkbidiv>
			<zkbidiv jxId="stmd_lotno" labelPosition="invisible"></zkbidiv>
			</hlayout>
		</vlayout>
	</template>
	<template name="template_erpv4_MoDetG2_stmd_qtydiv" twidth="hflex=min">
		<vlayout>
		 	<hlayout>
			<zkbidiv jxId="stmd_entryqty" labelPosition="invisible"></zkbidiv>
			<zkbidiv jxId="stmd_entryunit" labelPosition="invisible"></zkbidiv>
			</hlayout>
		</vlayout>
	</template>
	<template name="template_erpv4_MoDetG2_stmd_price" twidth="hflex=min">
		<vlayout>
			<zkbidiv jxId="stmd_uprice" labelPosition="invisible"></zkbidiv>
		</vlayout>
	</template>
	<template name="template_erpv4_MoDetG2_stmd_amount" twidth="hflex=min">
		<vlayout>
			<zkbidiv jxId="stmd_exprice" labelPosition="invisible"></zkbidiv>
		</vlayout>
	</template>
</zk>
