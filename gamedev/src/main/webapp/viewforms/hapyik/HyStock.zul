		<row>
			<cell colspan="2">
			Transaction Details :-
			</cell>
		</row>
		<row>
			<cell colspan="6">
			<listbox id="list_AfsStockMove">
			</listbox>
			</cell>
		</row>
		
		<row>
			<cell align="right"><label></label> </cell>
			<cell> </cell>
			<cell colspan="2"></cell>
			<cell></cell>
			<cell>
				<hbox align="middle">
				<div width="50px">Sold</div>
