<zk>
<style dynamic="true">

<!-- cut/hide the vertical borders in the grid rows -->
.myGridWithNoBorder tr.z-row td.z-row-inner { border-right: 0px #CCC; }
.GridLayoutNoBorder tr.z-row td.z-row-inner, tr.z-row .z-cell,div.z-grid 
{ 
border: none; 
overflow: hidden; 
zoom: 1; 
#background:#f8f8f8 !important;  <!-- remove hover -->
background:white !important;  <!-- remove hover -->
border-top: none; 
border-left: none; 
border-right: none; 
border-bottom: none; 
} 
</style>
	<grid style="text-align:left;border: 1px solid #000;" id="detail_grid"  sclass="GridLayoutNoBorder" >
	<columns>
		<column width="160px"></column>
		<column width="600px"></column>
		<column width="160px"></column>
		<column width="450px"></column>
		<column></column>
		<column width="300px"></column>
	</columns>
	<rows>
		<row>
			<cell align="right"><label>Category</label> </cell>
			<cell>
			<hlayout>
				<combobox id="mt_tpname" width="400px"></combobox>
			</hlayout>
			</cell>
			<cell align="right"><label></label></cell>
			<cell>
			</cell>
			<cell></cell>
			<cell>
				<label>Ref No.:</label>
				<label id="st_irg"></label>
			</cell>
		</row>
		<row>
			<cell align="right"><label>Item Code</label> </cell>
			<cell>
				<hbox align="middle">
				<combobox id="st_icode"></combobox> 
				</hbox>
			</cell>
			<cell align="right"><label>Obsoleted</label></cell>
			<cell>
				<checkbox id="st_obsolete"></checkbox>
			</cell>
			<cell></cell>
			<cell>
				<label>Customer Code:</label>
				<label id="inv_vcode"></label>
			</cell>
		</row>
		<row>
			<cell align="right"><label>Item Name</label> </cell>
			<cell>
				<textbox id="st_iname" width="560px"></textbox>
			</cell>
			<cell align="right"><label>Net Weight</label> </cell>
			<cell>
					<intbox id="st_netweight"></intbox>
			</cell>
			<cell></cell>
			<cell>
				<label>Create By:</label>
				<label id="st_cuser"></label>
			</cell>
		</row>
		<row>
			<cell align="right"><label>Chinese Name</label> </cell>
			<cell>
				<textbox id="st_einame" width="560px"></textbox>
			</cell>
			<cell align="right"><label>Reorder Level</label> </cell>
			<cell>
				<hlayout valign="middle">
				<doublebox id="st_lowmark" width="100px"></doublebox>
				<label>-</label>
				<doublebox id="st_highmark" width="100px"></doublebox>
				</hlayout>
			</cell>
			<cell></cell>
			<cell>
				<label>Create On:</label>
				<label id="st_cdate"></label>
			</cell>
		</row>
		<row>
			<cell align="right"><label>Remark</label> </cell>
			<cell>
				<textbox id="st_remark" width="500px"></textbox>
			</cell>
			<cell align="right"><label>Stock Unit</label> </cell>
			<cell>
				<combobox id="st_unit" width="100px"></combobox>
			</cell>
			<cell></cell>
			<cell>
				<label>Update By:</label>
				<label id="st_uuser"></label>
			</cell>
		</row>
		<row>
			<cell align="right"><label>Cost</label> </cell>
			<cell>
				<hlayout valign="middle">
				<doublebox id="st_standardcost"></doublebox>
				<combobox id="st_standardcostcur" width="100px"></combobox>
				<div style="text-align:right" width="100px"><label>Last Purchase</label> </div>
				<label id="st_lastpcost"></label>
				</hlayout>
			</cell>
			<cell align="right"><label>Composite Unit 1</label> </cell>
			<cell>
				<hlayout valign="middle">
				<textbox width="60px" id="st_munit1"/>
				<label>=</label>
				<doublebox width="40px" id="st_msize1"></doublebox>
				<textbox width="60px" id="st_dunit1"/>
				</hlayout>
			</cell>
			<cell></cell>
			<cell>
				<label>Update On:</label>
				<label id="st_udate"></label>
			</cell>
		</row>
		<row>
			<cell align="right"><label>Price</label> </cell>
			<cell>
				<hlayout valign="middle">
				<doublebox id="st_standardprice"></doublebox>
				<combobox id="st_standardcur" width="100px"></combobox>
				<div style="text-align:right" width="100px"><label>Last Sell</label> </div>
				<label id="st_lastsprice"></label>
				</hlayout>
			</cell>
			<cell align="right"><label>Composite Unit 1</label> </cell>
			<cell>
				<hlayout valign="middle">
				<textbox width="60px" id="st_munit2"/>
				<label>=</label>
				<doublebox width="40px" id="st_msize2"></doublebox>
				<textbox width="60px" id="st_dunit2"/>
				</hlayout>
			</cell>
			<cell>
			</cell>
		</row>
		<row>
			<cell align="right"><label>Discount 1</label> </cell>
			<cell>
				<hlayout valign="middle">
					<doublebox width="100px" id="st_price1"></doublebox>
					<label>or</label>
					<doublebox width="40px" id="st_disc1"></doublebox>
					<label>%</label>
				</hlayout>
			</cell>
			<cell align="right"><label>Composite Unit 1</label> </cell>
			<cell>
				<hlayout valign="middle">
				<textbox width="60px" id="st_munit3"/>
				<label>=</label>
				<doublebox width="40px" id="st_msize3"></doublebox>
				<textbox width="60px" id="st_dunit3"/>
				</hlayout>
			</cell>
			<cell></cell>
			<cell>
			</cell>
		</row>
		<row>
			<cell align="right"><label>Discount 2</label> </cell>
			<cell>
				<hlayout valign="middle">
					<doublebox width="100px" id="st_price2"></doublebox>
					<label>or</label>
					<doublebox width="40px" id="st_disc2"></doublebox>
					<label>%</label>
				</hlayout>
			</cell>
			<cell align="right"><label></label> </cell>
			<cell>
			</cell>
			<cell></cell>
			<cell>
			</cell>
		</row>
		<row>
			<cell align="right"><label>Discount 3</label> </cell>
			<cell>
				<hlayout valign="middle">
					<doublebox width="100px" id="st_price3"></doublebox>
					<label>or</label>
					<doublebox width="40px" id="st_disc3"></doublebox>
					<label>%</label>
				</hlayout>
			</cell>
			<cell align="right"><label></label> </cell>
			<cell>
			</cell>
			<cell></cell>
			<cell>
			</cell>
		</row>
