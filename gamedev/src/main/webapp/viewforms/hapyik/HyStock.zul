			<cell colspan="2"></cell>
			<cell></cell>
			<cell>
				<hbox align="middle">
				<div width="50px">Free</div>
				<doublebox id="stg_onorder"></doublebox>
				<doublebox id="stg_freestock"></doublebox>
				</hbox>
