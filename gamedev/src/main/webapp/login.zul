<zk>
<style>
<!-- 210602 obsoleted replaced by zkbi-whitebg
.grid_nohover_noselect tr.z-row td.z-row-inner, tr.z-row .z-cell,div.z-grid { 
	background:white !important; 
	-webkit-touch-callout: none;
    -webkit-user-select: none;
    -khtml-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
    user-select: none;
}
div.grid_nohover_noselect div.z-grid-body {
    height: auto !important;
