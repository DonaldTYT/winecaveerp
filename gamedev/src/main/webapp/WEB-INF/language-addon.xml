<language-addon>
	<addon-name>zkbi-addon</addon-name>
	<version>1.0</version>
	<language-name>xul/html</language-name>
	<!-- 
	<depends>zuti</depends>
	 -->

	<!-- bootstrap row-->
	<component>
		<component-name>bs-row</component-name>
		<extends>div</extends>
		<property>
			<property-name>sclass</property-name>
			<property-value>bs-row row py-1</property-value>
		</property>
	</component>
	
	<!-- 2 col -->
	<component>
		<component-name>bs-col-2</component-name>
		<extends>div</extends>
		<property>
			<property-name>sclass</property-name>
			<property-value>col-2</property-value>
		</property>
	</component>
	
	<!--  3 col -->
	<component>
		<component-name>bs-col-3</component-name>
		<extends>div</extends>
		<property>
			<property-name>sclass</property-name>
			<property-value>col-3</property-value>
		</property>
	</component>
	
	
	<!-- large,middle 2 col, small 1 col -->
	<component>
		<component-name>bs-col-221</component-name>
		<extends>div</extends>
		<property>
			<property-name>sclass</property-name>
			<property-value>col-lg-6 col-md-6</property-value>
		</property>
	</component>
	
	<!-- large 2 col, small/middle 1 col -->
	<component>
		<component-name>bs-col-211</component-name>
		<extends>div</extends>
		<property>
			<property-name>sclass</property-name>
			<property-value>col-lg-6 col-md-12</property-value>
		</property>
	</component>
	
	
	<!-- large 3 col, middle 2 col, small 1 col -->
	<component>
		<component-name>bs-col-321</component-name>
		<extends>div</extends>
		<property>
			<property-name>sclass</property-name>
			<property-value>col-lg-4 col-md-6</property-value>
		</property>
	</component>
	
	
	<!-- large 3 col, middle 1 col, small 1 col -->
	<component>
		<component-name>bs-col-311</component-name>
		<extends>div</extends>
		<property>
			<property-name>sclass</property-name>
			<property-value>col-lg-4 col-md-12</property-value>
		</property>
	</component>
	
	

