	<component>
		<component-name>zkbi-form</component-name>
		<extends>window</extends>
		<property>
			<property-name>class</property-name>
			<property-value>zkbi-form zkbi-main-window</property-value>
		</property>
		<property>
			<property-name>width</property-name>
			<property-value>100%</property-value>
		</property>
		<property>
			<property-name>title</property-name>
			<property-value></property-value>
		</property>
		<property>
			<property-name>border</property-name>
			<property-value>none</property-value>
		</property>
	</component>
	
	<component>
		<component-name>zkbi-form-header</component-name>
		<extends>label</extends>
		<property>
			<property-name>sclass</property-name>
			<property-value>zkbi-form-header</property-value>
		</property>
		<property>
			<property-name>id</property-name>
			<property-value>lbHeader</property-value>
