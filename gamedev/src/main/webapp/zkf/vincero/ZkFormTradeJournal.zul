					<listcell>
						<doublebox id="tradj_stbal"> </doublebox>
					</listcell>
				</listitem>
				<listitem>
					<listcell label="Current Balance"/>
					<listcell>
						<doublebox id="tradj_curbal"> </doublebox>
					</listcell>
				</listitem>
				<listitem>
