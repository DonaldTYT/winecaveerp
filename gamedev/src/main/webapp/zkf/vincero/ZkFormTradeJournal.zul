						<intbox id="tradj_ltrade"> </intbox>
					</listcell>
				</listitem>
				<listitem>
					<listcell label="Breakeven Trades"/>
					<listcell>
						<intbox id="tradj_btrade"> </intbox>
					</listcell>
				</listitem>
				<listitem>
					<listcell label="% Winning Trades"/>
					<listcell>
						<doublebox id="tradj_percentwin"> </doublebox>
					</listcell>
				</listitem>
				<listitem>
					<listcell label="Average Win"/>
					<listcell>
						<doublebox id="tradj_averagewin"> </doublebox>
					</listcell>
				</listitem>
				<listitem>
					<listcell label="Average Loss"/>
					<listcell>
						<doublebox id="tradj_averageloss"> </doublebox>
					</listcell>
				</listitem>
		</listbox>
		<listbox id="lb_breakdown" hflex="min" visible="true">
				<auxhead>
					<auxheader id="hdr_breakdown" label="Monthly Breakdown and Averages" colspan="3"/>
				</auxhead>
				<listhead>
					<listheader width="70px">Month</listheader>
					<listheader width="80px">% Gain</listheader>
