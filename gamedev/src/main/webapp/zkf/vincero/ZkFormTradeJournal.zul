<zk>
<script>
	function setPlotChartStyle(classname) {
	    const targetId = classname + "_canvas";

	    let retryCount = 0;
	    const maxRetries = 30;  // 最多等 3 秒
	    const intervalMs = 100; // 每 100ms 檢查一次

	    const interval = setInterval(() => {
	        const target = document.getElementById(targetId);
	        if (target) {
	            target.style.backgroundColor = "white";  // 可自訂背景色
	            target.style.border = "1px solid #ccc";
	            target.style.borderRadius = "20px";
	            target.style.marginTop = "20px";
	            clearInterval(interval);
	        } else {
	            retryCount++;
	            if (retryCount >= maxRetries) {
	                clearInterval(interval);
	                alert("找不到元素：" + targetId);
	            }
	        }
	    }, intervalMs);
	}

	function setEditlistboxStyle(classname) {
	    const targetId = classname + "-body";

	    let retryCount = 0;
	    const maxRetries = 30;  // 最多等 3 秒
	    const intervalMs = 100; // 每 100ms 檢查一次

	    const interval = setInterval(() => {
	        const target = document.getElementById(targetId);
	        if (target) {
	            target.style.overflow = "unset";
	        } else {
	            retryCount++;
	            if (retryCount >= maxRetries) {
	                clearInterval(interval);
	                alert("找不到元素：" + targetId);
	            }
	        }
	    }, intervalMs);
	}

</script>
    <style>
        /* Align text to the top for the second column */
        .custom-listbox .z-listcell {
            vertical-align: top !important;
        }

        .btn_Chart {
        	padding: 10px 20px !important;
        	margin-right: 30px;
        	margin-left: 20px;
        }

        <!--.z-window-content{
        	height: 1546px !important;
        }-->

        .z-window-content, .z-window {
		    border: none !important;
		    background: transparent !important;
		    box-shadow: none !important;
		}

		z-listbox-body {
			overflow: unset !important;
		}

    </style>
<window sclass="zkbi-form zkbi-main-window" width="1650px" apply="com.uniinformation.zkf.vincero.ZkCellActionTradeJournal">
	<tabbox id="zkbiListTop" width="100%">
		<tabs width="100%">
			<tab id="tb_total">Total</tab>
			<tab id="tb_Jan">Jan</tab>
			<tab id="tb_Feb">Feb</tab>
			<tab id="tb_Mar">Mar</tab>
			<tab id="tb_Apr">Apr</tab>
			<tab id="tb_May">May</tab>
			<tab id="tb_Jun">Jun</tab>
			<tab id="tb_Jul">Jul</tab>
			<tab id="tb_Aug">Aug</tab>
			<tab id="tb_Sep">Sep</tab>
			<tab id="tb_Oct">Oct</tab>
			<tab id="tb_Nov">Nov</tab>
			<tab id="tb_Dec">Dec</tab>
		</tabs>
	</tabbox>
	<hlayout>
