				</listitem>
		</listbox>
	</vlayout>
	<div width="20px"></div>
	<vlayout>
		<listbox class="custom-listbox" id="lb_tradedetail" style="width: 100%; overflow: unset !important;" hflex="min" visible="false" sclass="zkbi-linkcomp-listbox">
				<auxhead>
					<auxheader id="hdr_tradedetail" colspan="10" style="padding: 4px;">
						<hbox width="100%">
							<div hflex="1" style="text-align: left;">
							<label>Trade Details</label>
							</div>
							<button id="btNewTrade" style="margin-left:auto; margin-right: 10px;">New Trade</button>
						</hbox>
