					<listheader width="100px">Reward to Risk</listheader>
					<listheader width="100px">Setup Frame</listheader>
					<listheader width="160px">Time Taken</listheader>
					<listheader width="180px">Reason For Trade</listheader>
					<listheader width="180px">Comments</listheader>
					<listheader width="100px"></listheader>
				</listhead>
				
				<listitem id="liNewTrade" style=" border-style: inset;">
					<listcell style="vertical-align:top;"> 
						<vlayout>
						<datebox id="trnew_date" placeholder="Required"> </datebox> 
						</vlayout>
					</listcell>
					<listcell style="vertical-align:top;"> 
						<vlayout>
						<textbox id="trnew_ccy" style="background-color: yellow;"> </textbox> 
						</vlayout>
					</listcell>
					<listcell style="vertical-align:top;"> 
						<vlayout>
						<hlayout><div width="80px">Buy/Sell</div><combobox id="trnew_buysell" width="100px" style="background-color: yellow;">
						<comboitem label="Buy" value="Buy"></comboitem>
						<comboitem label="Sell" value="Sell"></comboitem>
						</combobox></hlayout>
						<hlayout><div width="80px">Entry</div><doublebox style="background-color: yellow;" id="trnew_entry"> </doublebox> </hlayout>
						<hlayout><div width="80px">Exit</div><doublebox style="background-color: yellow;" id="trnew_exit"> </doublebox></hlayout>
						<hlayout><div width="80px">Stop Loss</div><doublebox style="background-color: yellow;" id="trnew_stoplost"> </doublebox> </hlayout>
						<hlayout><div width="80px">Take Profit 1</div><doublebox style="background-color: yellow;" id="trnew_takeprofit"> </doublebox> </hlayout>
						<hlayout><div width="80px">Take Profit 2</div><doublebox style="background-color: yellow;" id="trnew_takeprofit2"> </doublebox> </hlayout>
						</vlayout>
					</listcell>
					<listcell style="vertical-align:top;"> 
						<doublebox id="trnew_pl" style="background-color: yellow;"> </doublebox> </listcell>
					<listcell style="vertical-align:top;"> 
						<doublebox id="trnew_rewardtorisk" style="background-color: yellow;"> </doublebox>
					</listcell>
					<listcell style="vertical-align:top;"> <textbox style="background-color: yellow;" id="trnew_timeframe" > </textbox> </listcell>
					<listcell style="vertical-align:top;"> <datebox id="trnew_timetaken" format="long+medium" width="160px"> </datebox> </listcell>
					<listcell style="vertical-align:top;"> <textbox hflex="1" style="background-color: yellow;" id="trnew_reason" rows="4"> </textbox> </listcell>
					<listcell style="vertical-align:top;"> <textbox hflex="1" style="background-color: yellow;" id="trnew_comments" rows="4"> </textbox> </listcell>
					<listcell style="vertical-align:top;">
						<vlayout>
