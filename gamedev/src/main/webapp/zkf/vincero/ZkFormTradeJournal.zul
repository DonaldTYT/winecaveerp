	<div id="div_chart" visible="true">
        
        <hbox style="margin-top: 20px; width: 100%;">
        <div style="width: 100%; text-align: center;">
            <button id="plotButton" class="btn_Chart" label="Plot Chart"/>
            <button id="clearButton" class="btn_Chart" label="Clear Chart"/>
        </div>

        </hbox>
     
	        
	    
        <div id="chartContainer" style="width: 700px; height: 500px;"></div>
	</div>
	</vlayout>
	</hlayout>
</window>
</zk>