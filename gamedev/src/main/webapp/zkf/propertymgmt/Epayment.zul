			</listitem>
		</listbox>
		<div style="display:flex; align-items: center;padding:10px;color:black;background:white">
			<label style="font-size: 36px;">繳費至（月份）：</label>
			<label id="lb_paidto" style="font-size: 36px;"></label>
			<span style="flex:auto"/>
			<label style="font-size: 46px;font-weight:bold">總金額：</label>
			<label id="lb_paidtotal" style="font-size: 46px;font-weight:bold"></label>
		</div>
		<hlayout height="350px">
			<div id="div_paymonth" hflex="1" vflex="1" sclass="div_paymonth">
				<button id="btPrevPayMnt" sclass="btn_green4 prev" visible="false">&lt;</button>
				<button id="btNextPayMnt" sclass="btn_green4 next" visible="false">&gt;</button>
			</div>
			<hbox pack="start" align="center" width="310px" vflex="1">
				<button id="btConfirmPay" class="btn_Confirm" style="width: 250px; height: 100px; font-size:50px !important;">支付 Pay</button>
			</hbox>
		</hlayout>
		<separator height="65px"/>
	</div>
</div>

<div align="center" class="bottom-div">
	
		<div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
			<label id="ldv_comment" style="font-size:40px !important;  margin: 0 auto;">Please Select Building</label>
			<button id="ldv_exit" class="btn_exit" style="margin-right: 30px;">退出 Exit</button>
		</div>
	
</div>
<template name="template_payUnit">
		<div height="calc(max(100vh, 1450px) - 540px - 86px - 350px - 65px)" sclass="div_payunit">
			<div sclass="row-odd" style="padding:10px;background:#bcd6ed;">
				<label id="unit_name" style="display: block; font-size: 46px; font-weight: bold;">Unit Name</label>
			</div>
			<div sclass="row-even" style="flex:auto;padding:10px">
				<separator height="10px"/>
				<div style="display:flex;align-items:center;">
					<label id="unit_mgtfromlabel">已繳管理費（月份）：</label>
					<label id="unit_mgtfrom">Mgt from</label>
					<span style="flex:auto"/>
					<label id="unit_mgtfeelabel">管理費（每月）：</label>
					<label id="unit_mgtfee" style="min-width:125px;text-align:right">Mgt Fee</label>
				</div>
				<separator height="10px"/>
				<div style="display:flex;align-items:center">
					<label id="unit_resfromlabel">已繳儲備金（月份）：</label>
					<label id="unit_resfrom">Mgt from</label>
					<span style="flex:auto"/>
					<label id="unit_resfeelabel">儲備金（每月）：</label>
					<label id="unit_resfee" style="min-width:125px;text-align:right">Mgt Fee</label>
				</div>
			</div>
			<div sclass="row-odd" style="padding:10px;flex:auto;overflow-y:auto">
				<separator height="10px"/>
				<label>本次繳費：</label>
				<div id="unit_mgtcurdiv">
					<separator height="10px"/>
					<div style="display:flex;align-items:center">
						<label id="unit_mgtcurl">管理費（月份）：</label>
						<label id="unit_mgtcur">from 至 to（fee * count）</label>
						<span style="flex:auto"/>
						<label id="unit_mgtcurfee"></label>
					</div>
				</div>
				<div id="unit_rescurdiv">
					<separator height="10px"/>
					<div style="display:flex;align-items:center">
						<label id="unit_rescurl">儲備金（月份）：</label>
						<label id="unit_rescur">from 至 to（fee * count）</label>
						<span style="flex:auto"/>
						<label id="unit_rescurfee"></label>
					</div>
				</div>
			</div>
		</div>
</template>
</div>
</zk>
