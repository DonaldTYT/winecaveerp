}

.btn_green6:active, .btn_green6:focus{
	background-color: #c5e0b4;
}

.btn_split{
	background-color: #FFFFFF;
	border: 2px solid #b3b3b3;
	border-radius: 10px;
	color: black;
	width: 170px;
	height: 70px;
	font-size: 25px;
	margin: 30px 20px 0px;
	box-shadow: 9px 9px 6px #71808e;
}

.btn_split:focus, .btn_split:active{
	background-color: #4D4D4D;
	color: white;
}

.btn_Confirm{
	border: 3px solid #00af50;
	border-radius: 15px;
	background-color: #00af50;
	color: white;
	width: 120px;
	height: 100px;
	font-size: 30px;
