<zk>
<script>
<![CDATA[
function postQrCodeData(p_str) {
	var zkComp = zk.Widget.$('$barcodeS1');
	if (zkComp !== null && zAu !== null)
		zAu.send(new zk.Event(zkComp, "onPostQrCodeData", p_str, {toServer:true}));
	else
		console.log("comp or zAu is null, skip register event");
}
const payMonthButtons = (() => {
	let $btns;
	let $btnPrev;
	let $btnNext;
	const isShow = ($btn) => {
		const ctrRect = $(".div_paymonth")[0].getBoundingClientRect();
		const btnRect = $btn[0].getBoundingClientRect();
		return btnRect.top >= ctrRect.top && btnRect.bottom <= ctrRect.bottom;
	};
	const getFirstVisible = () => $btns.filter(":visible").first();
	const getLastVisible = () => $btns.filter(":visible").last();
	const getFirstVisibleIndex = () => $btns.index(getFirstVisible());
	const getLastVisibleIndex = () => $btns.index(getLastVisible());
	const show = () => {
		const firstButtonIdx = jq('$div_paymonth').data("first_button_index") | 0;
		//console.log("firstButtonIdx", firstButtonIdx);
		let firstShowIdx, lastShowIdx;
		if (firstButtonIdx < 0)
			lastShowIdx = -firstButtonIdx;
		else
			firstShowIdx = firstButtonIdx;
		const $eles = $(".div_paymonth button").hide();
		$btns = $eles.not(".prev,.next");
		$btnPrev = $eles.filter(".prev");
		$btnNext = $eles.filter(".next");
		$.each(lastShowIdx ? $btns.get().slice(0, lastShowIdx + 1).reverse() : $btns.get().slice(firstShowIdx), function(index) {
			$(this).show();
			if (!isShow(getLastVisible())) {
				$(this).hide();
				return false;
			}
		});
		firstShowIdx = getFirstVisibleIndex();
		lastShowIdx = getLastVisibleIndex();
		if (firstShowIdx > 0 && lastShowIdx > 0) {
			if (!isShow($btnPrev.show())) {
				if (firstButtonIdx < 0)
					$($btns[firstShowIdx++]).hide();
				else
					$($btns[lastShowIdx--]).hide();
			}
		}
		if (firstShowIdx >= 0 && lastShowIdx >= 0 && lastShowIdx < $btns.length - 1) {
			if (!isShow($btnNext.show())) {
				if (firstButtonIdx < 0)
					$($btns[firstShowIdx++]).hide();
				else
					$($btns[lastShowIdx--]).hide();
			}
		}
	};
	const showPrev = () => {
		jq('$div_paymonth').data("first_button_index", -(getFirstVisibleIndex() - 1));
		show();
	};
	const showNext = () => {
		jq('$div_paymonth').data("first_button_index", getLastVisibleIndex() + 1);
		show();
	};
	return { show: show, showPrev: showPrev, showNext: showNext };
})();
]]>
</script>
<style>


.btn_four {
	width: 600px;
    height: 212px;
    background-color: unset;
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
