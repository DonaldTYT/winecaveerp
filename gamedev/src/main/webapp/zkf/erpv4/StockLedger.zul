<zk>
<div align="middle">
	<vlayout width="600px">
		<div height="30px"/>
		<div align="center">Stock Ledger Report</div>
		<div height="30px"/>
		<hlayout valign="middle" id="cond_icode" use="com.uniinformation.zkbi.QueryConditionRow">
				<custom-attributes fdname="st_icode"></custom-attributes>
		</hlayout>
		<!--
		<hlayout valign="middle" id="rpt_date" use="com.uniinformation.zkbi.QueryConditionRow">
				<custom-attributes fdname="stm_date"></custom-attributes>
		</hlayout>
		-->
		<hlayout valign="middle" id="cond_date" use="com.uniinformation.zkbi.QueryConditionRow">
				<custom-attributes fdname="rpt_date"></custom-attributes>
				<custom-attributes fdtype="date"></custom-attributes>
				<custom-attributes label="Date Range"></custom-attributes>
		</hlayout>
		<div height="30px"/>
		<hlayout valign="middle">
				<checkbox id="rpt_showdetail" label="Show Detail"/>
		</hlayout>
		<div height="30px"/>
		<button width="100px" id="btPrint" label="Print">
			<!-- 
				<custom-attributes actionHandler="com.uniinformation.erpv4.PerfJsonRpcCall" actionId="erpv4TestJsonRpc"></custom-attributes>
			 -->
			<!-- 
				<custom-attributes actionHandler="com.uniinformation.erpv4.PerfJsonRpcReportA4L" actionId="erpv4PrintAgingRpt" actionData="{'fileName':'ar_aging_report.pdf'}"></custom-attributes>
				<custom-attributes tlkey="bt_print"></custom-attributes>
			 -->
		</button>
	</vlayout>
</div>
<!--
	<div visible="false">
		<textbox id="cocode" text="001"></textbox>
	</div>
-->
</zk>