<zk>
<script><![CDATA[
         function beep(beepId) {
              if (beepId == 1){
              		var snd = new Audio("data:audio/wav;base64,");
                         	snd.play();
              }
              else{
                	var snd = new Audio("data:audio/wav;base64,");
                         	snd.play();
             }
        }
        function processUrlEncodedJson(p_json){
                var json = JSON.parse(decodeURIComponent(p_json));
                console.log("processUrlEncodedJson:" + JSON.stringify(json));
                var action = json['action'];
                var value = json['value'];
                var version = json['version'];
                
                var txNewBarcode = zk.Widget.$('$txNewBarcode');
                //fire onchange event, (good)
                txNewBarcode.$n().value=(value);
                txNewBarcode.updateChange_();
        }
        function afterScanner(){
			var btScanE = zk.Widget.$('$btScanE');
			if (btScanE !== null && zAu !== null && zk !== null)
				zAu.send(new zk.Event(btScanE, "onClick", null, {toServer:true}));
        }
        function launchScanner(){
            if (typeof android !== "undefined"){
            	android.launchScanner();
            }
            else if (typeof webkit !== "undefined"){
            	try{
                	webkit.messageHandlers.callbackHandler.postMessage("scanBarcode");
            	}
            	catch(err){
            		alert("Unable to open barcode scanner : " +  err);
            	}
            }
            else{
           		alert("Unable to open barcode scanner : unknown decice");
            }
        }
        function closeScanner(){
            if (typeof android !== "undefined")
            	android.closeScanner();
            else
           		alert("Unable to open barcode scanner : unknown decice");
        }
    ]]>
</script>
<window apply="com.uniinformation.zkf.erpv4.ZkMobileBarcode" width="100%" height="100px">
	<vlayout>
		<div height="10px"></div>
		<div align="center" > <label id="scannerId" hflex="1" ></label>  </div>
		<div height="10px"></div>
		<div align="center" > <label id="readBarcode" hflex="1" ></label>  </div>
	</vlayout>
<!-- 
	<vlayout visible="false">
		<div align="center" visible = "false">Barcode Scanner</div>
		<div align="center" visible="false">
		</div>
	</vlayout>
 -->
	<div visible="false">
			<button id="btScanE" visible="false">ScanOK</button>
    		<textbox id="txNewBarcode" visible="false"> <custom-attributes org.zkoss.zk.ui.updateByClient="true"/> </textbox>
			<button id="bt_scan">Scan</button>
	</div>
</window>
</zk>