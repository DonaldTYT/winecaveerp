						<template name="Pdx_pdttemplate">
				<row id="Pdx_pdtpanel" spans="1,2">
				<!-- 
        		 			<div width="120px"> 
				 -->
				 			<cell valign="top" style="background-color: #6DB33F">
        		 			<vlayout>
        		 				<textbox id="Pdx_pdtname"> </textbox> 
	        		 			<button id="btDelProduct">Delete</button>
        		 			</vlayout>
				 			</cell>
	        		 		<vlayout id="Pdx_pdtext"> 
	        		 					<hlayout>
											<button id="btAddPdtExtent">Add Item</button>
											<combobox id="cbAddPdtExtent"></combobox>
	        		 					</hlayout>
										<template name="Pdx_pdtexttemplate">
	        		 						<hlayout id="Pdx_pdtextpanel" valign="top">
	        		 							<vlayout>
							        		 		<div width="150px"> <textbox id="Pdx_pdtextname"> </textbox> </div>
			        		 						<button id="btDelExtent">Delete</button>
	        		 							</vlayout>
	        		 							<vlayout>
	        		 							<hlayout>
							        			<div width="60px">
							        				<label>Color</label>
				            						<intbox id="Pdx_fcol" width="20px"/>
							        			</div>
	        		 							<div width="250"> 
	        		 								<hlayout valign="middle">
	        		 									Size	
				            							<doublebox id="Pdx_xd" width="50px"/>
				            							x
				            							<doublebox id="Pdx_xw" width="50px"/>
				            							Quantity
				            							<intbox id="Pdx_qty" width="50px"/>
	        		 								</hlayout>
	        		 							</div>
	        		 							</hlayout>
	        		 							<hlayout>
	        		 							Material
		        		 						<combobox id="Pdx_mattype" width="200px"></combobox>
    		    		 						<combobox id="Pdx_matname" width="200px"></combobox>
        				 						<combobox id="Pdx_matwt" width="80px"></combobox>
	        		 							</hlayout>
        		 								<grid id="Pdx_optionlist" use="com.uniinformation.jx.zk.ZkJxCheckListBox" width="600px" > </grid>
	        		 							</vlayout>
        		 							</hlayout>	
				        		 		</template>
	        		 		</vlayout>
				</row>
						</template>
				<row spans="1,2">
						Jobs
						<hlayout>
							<button id="btAddProduct">Add Job</button>
							<combobox id="cbAddProduct"></combobox>
						</hlayout>
						</row>
