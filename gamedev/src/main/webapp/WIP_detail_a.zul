<window border="normal" width="1000px" title="Welcome" apply="com.uniinformation.jx.zk.ZkJxComposer" id="WOEST_detail">
<grid id="Pc_je_detail">
   	<columns>
      <column width="200px"/><!-- define 2 columns to enable auxhead/er -->
      <column width="120px"/>
      <column/>
	</columns>
    <rows id="Pdx_extents">
       <row> 
       		Customer Code/Name
       		<combobox id="Pdg_custcode" width="100px"></combobox> 
       		<textbox id="Pdg_custname" width="600px" disabled="true"></textbox>
       </row>
       <row> 
       		Project Number/Title
       		<intbox id="Pdg_jobnum" width="100px" disabled="true"></intbox>
       		<textbox id="Pdg_title" width="600px"></textbox> 
       </row>
        		 <row spans="1,2">Category
        		 	<hlayout>
        		 	<combobox id="Pdg_catname" width="500px"></combobox>
