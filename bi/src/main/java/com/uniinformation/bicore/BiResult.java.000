	public BiResult getSubLink(String p_viewName) {
		Vector v = sublinks;
		if(v != null) {
			for(int i = 0;i<v.size();i++) {
				BiResult br = (BiResult) v.get(i);
				if(br.getView().getName().equals(p_viewName)) return(br);
