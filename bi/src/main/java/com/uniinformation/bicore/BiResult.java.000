					if(ca instanceof BiAggregateCellValueAction) {
						String detailCell = ((BiAggregateCellValueAction) ca).getDetailCellLabel();
						Cell cc = p_col.getCell(detailCell);
						if(cc != null) {
							cc.addAction(ca);
						}
					}
				}
				}
			}
		}
		
		p_col.afterCreateColumnCells();
	}
	public BiResult getParent()
	{
		return(parent);
	}
